---
import { siteConfig, coordsShort } from '../config';

const year = new Date().getFullYear();

const waypoints = [
  { label: 'Origin', href: '/#about', coord: '01', bearing: '045°' },
  { label: 'Logbook', href: '/blog', coord: '02', bearing: '120°' },
  { label: 'Library', href: '/books', coord: '03', bearing: '210°' },
  { label: 'Signal', href: '/#contact', coord: '04', bearing: '315°' },
];
---

<footer class="border-t border-[var(--color-edge)] pt-16 pb-10 px-6 md:px-12 reveal">
  <div class="max-w-5xl mx-auto">
    <div class="grid md:grid-cols-3 gap-10 mb-12">
      <!-- Compass Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-4 group">
          <div class="w-7 h-7 relative flex items-center justify-center">
            <div class="absolute inset-0 rounded-full border border-[var(--color-accent)]/30"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></div>
            <span class="absolute top-0 left-1/2 -translate-x-1/2 text-[5px] font-mono font-bold text-[var(--color-warm)]">N</span>
          </div>
          <div class="flex flex-col -space-y-0.5">
            <span class="text-sm font-semibold font-[family-name:var(--font-display)] text-[var(--color-text)]">{siteConfig.name.short}</span>
            <span class="text-[8px] font-mono faint tracking-[0.15em]">{coordsShort}</span>
          </div>
        </a>
        <p class="text-xs dim leading-relaxed max-w-[260px]">
          {siteConfig.role} from {siteConfig.location.city}. {siteConfig.tagline}
        </p>
      </div>

      <!-- Waypoints -->
      <div>
        <span class="text-[10px] font-mono faint uppercase tracking-wider block mb-4">Waypoints</span>
        <div class="space-y-2">
          {waypoints.map(wp => (
            <a href={wp.href} class="flex items-center gap-3 text-sm dim hover:text-[var(--color-accent)] transition-colors group">
              <span class="text-[9px] font-mono faint group-hover:text-[var(--color-warm)] transition-colors">{wp.coord}</span>
              <span class="w-3 border-t border-dashed border-[var(--color-faint)]/30"></span>
              <span class="font-mono text-[13px]">{wp.label}</span>
              <span class="bearing-badge ml-auto">{wp.bearing}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Transmit -->
      <div>
        <span class="text-[10px] font-mono faint uppercase tracking-wider block mb-4">Transmit</span>
        <div class="space-y-2.5">
          <a href={siteConfig.social.github.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-sm dim hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href={siteConfig.social.linkedin.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-sm dim hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-8 border-t border-[var(--color-edge)]">
      <div class="flex items-center gap-3">
        <div class="w-1 h-1 rounded-full bg-[var(--color-tertiary)]"></div>
        <span class="text-xs dim">&copy; {year} {siteConfig.name.full}</span>
      </div>
      <div class="flex items-center gap-4">
        <a href={siteConfig.social.buymeacoffee.url} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-[11px] font-mono faint hover:text-[var(--color-warm)] transition-colors">
          <svg class="w-3 h-3 text-[var(--color-warm)] opacity-50 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8h1a4 4 0 110 8h-1M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8zM6 2v4M10 2v4M14 2v4"/></svg>
          brewed with coffee at 13°N
        </a>
        <button id="back-to-top" class="w-8 h-8 rounded-lg border border-[var(--color-edge)] flex items-center justify-center faint hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/30 transition-all cursor-pointer" aria-label="Back to top">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 15l7-7 7 7"/></svg>
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
