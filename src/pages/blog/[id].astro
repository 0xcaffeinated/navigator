---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const words = (post.body || '').trim().split(/\s+/).length;
const readTime = Math.max(1, Math.round(words / 230));
---

<BaseLayout title={`${post.data.title} — ${siteConfig.name.full}`} description={post.data.description}>

  <!-- BlogPosting structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": new Date(post.data.date).toISOString(),
    "author": { "@type": "Person", "name": siteConfig.name.full, "url": siteConfig.siteUrl },
    "wordCount": words,
    "timeRequired": `PT${readTime}M`,
    ...(post.data.tags ? { "keywords": post.data.tags.join(', ') } : {})
  })} />

  <article class="relative pt-20 pb-16 md:pt-32 md:pb-24 px-6 md:px-12">
    <div class="absolute inset-0 topo-grid"></div>
    <div class="max-w-3xl mx-auto relative">
      <a href="/blog" class="inline-flex items-center gap-2 dim hover:text-[var(--color-accent)] hover:-translate-x-1 transition-all duration-200 mb-14 reveal text-sm group font-mono">
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Return to logbook
      </a>

      <header class="mb-14 reveal">
        <!-- Log entry metadata -->
        <div class="flex items-center gap-2 mb-5">
          <div class="w-1 h-1 rounded-full bg-[var(--color-tertiary)]"></div>
          <span class="text-[9px] font-mono faint tracking-[0.15em] uppercase">Log Entry</span>
          <span class="text-[9px] font-mono faint">·</span>
          <span class="text-[9px] font-mono faint tracking-wider">{readTime} min transmission</span>
        </div>

        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span class="tag-warm">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          {post.data.location && <span class="tag">{post.data.location}</span>}
        </div>
        <h1 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold text-[var(--color-text)] leading-[1.2] mb-4">{post.data.title}</h1>
        <p class="text-lg dim leading-relaxed">{post.data.description}</p>
        {post.data.tags && (
          <div class="flex flex-wrap gap-1.5 mt-5">
            {post.data.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        )}
      </header>

      <div class="separator mb-12"></div>

      <div class="prose reveal"><Content /></div>

      <!-- Refuel -->
      <div class="mt-16 mb-16 flex justify-center reveal">
        <a href={siteConfig.social.buymeacoffee.url} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2.5 px-5 py-3 rounded-xl border border-dashed border-[var(--color-edge)] hover:border-[var(--color-warm)]/40 transition-all duration-300">
          <svg class="w-4 h-4 text-[var(--color-warm)] opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 8h1a4 4 0 110 8h-1M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8zM6 2v4M10 2v4M14 2v4"/></svg>
          <span class="text-[11px] font-mono faint group-hover:text-[var(--color-warm)] transition-colors tracking-wider">Refuel the navigator</span>
        </a>
      </div>

      <div class="pt-8 border-t border-dashed border-[var(--color-edge)] flex flex-wrap items-center justify-between gap-3">
        <a href="/blog" class="btn-ghost magnetic">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          <span>All entries</span>
        </a>
        <button id="share-btn" class="btn-ghost magnetic text-sm" aria-label="Copy link">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <span id="share-label">Copy link</span>
        </button>
      </div>
    </div>
  </article>

  <script>
    const btn = document.getElementById('share-btn');
    const label = document.getElementById('share-label');
    btn?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(window.location.href);
      if (label) {
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Copy link'; }, 2000);
      }
    });
  </script>

</BaseLayout>
