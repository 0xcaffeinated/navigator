---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig, devtoApiUrl } from '../../config';

// ── Emoji stripper for dev.to titles ──
function cleanTitle(title: string) {
  return title.replace(/^[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}\u{FE00}-\u{FE0F}\u{200D}\u{20E3}\u{E0020}-\u{E007F}]+\s*/u, '');
}

// ── Local posts — static at build time ──
const localPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .map(post => ({
    title: post.data.title,
    description: post.data.description,
    date: new Date(post.data.date).toISOString(),
    tags: post.data.tags || [],
    location: post.data.location as string | undefined,
    readTime: Math.max(1, Math.round((post.body || '').trim().split(/\s+/).length / 230)),
    href: `/blog/${post.id}`,
    source: 'local' as const,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// ── Dev.to view counts — fetched at build time with API key ──
let viewsMap: Record<number, number> = {};
try {
  const apiKey = import.meta.env.DEVTO_API_KEY;
  if (apiKey) {
    const pages = [];
    for (let page = 1; page <= 10; page++) {
      const res = await fetch(`https://dev.to/api/articles/me?per_page=100&page=${page}`, {
        headers: { 'api-key': apiKey },
      });
      if (!res.ok) break;
      const batch = await res.json();
      if (batch.length === 0) break;
      pages.push(...batch);
    }
    for (const a of pages) {
      viewsMap[a.id] = a.page_views_count || 0;
    }
  }
} catch {}

// ── Dev.to articles — fetched at build time (public API) ──
let devtoPosts: Array<{
  title: string; description: string; date: string; tags: string[];
  readTime: number; href: string; source: 'devto';
  reactions: number; comments: number; views: number;
}> = [];
let totalReactions = 0;
let totalComments = 0;
let totalViews = 0;

try {
  const res = await fetch(devtoApiUrl);
  if (res.ok) {
    const articles: any[] = await res.json();
    for (const a of articles) {
      totalReactions += a.public_reactions_count || 0;
      totalComments += a.comments_count || 0;
      const views = viewsMap[a.id] || 0;
      totalViews += views;
      devtoPosts.push({
        title: cleanTitle(a.title),
        description: a.description,
        date: new Date(a.published_at).toISOString(),
        tags: a.tag_list || [],
        readTime: a.reading_time_minutes,
        href: `/blog/dev/${a.slug}`,
        source: 'devto',
        reactions: a.public_reactions_count || 0,
        comments: a.comments_count || 0,
        views,
      });
    }
  }
} catch {}
---

<BaseLayout title={`Logbook — ${siteConfig.name.full}`}>

  <section class="relative pt-20 pb-16 md:pt-32 md:pb-24 px-6 md:px-12">
    <div class="absolute inset-0 topo-grid"></div>
    <div class="max-w-3xl mx-auto relative">
      <div class="mb-16 reveal">
        <div class="flex items-center gap-4 mb-8">
          <span class="flex items-center gap-2.5 section-label">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
            Logbook
          </span>
          <div class="flex-1 h-0 border-t border-dashed border-[var(--color-edge)]"></div>
          <span class="bearing-badge hidden md:block">03 / LOG</span>
        </div>
        <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-4">
          Field Notes<span class="accent-warm">.</span>
        </h1>
        <p class="dim text-lg max-w-lg">
          Observations from the intersection of code, history, and everywhere in between.
        </p>
      </div>

      <!-- Filter bar -->
      <div class="flex items-center gap-1.5 mb-8 reveal" id="log-filters">
        <button data-filter="devto" class="log-filter log-filter-active">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-.72.04-.75.03v1.77l1.22.03 1.2.04v1.28h-1.6c-1.53 0-1.6-.01-1.87-.3l-.3-.28v-3.16c0-3.02.01-3.18.25-3.48.23-.31.25-.31 1.88-.31h1.64v1.3zm4.68 5.45c-.17.43-.64.79-1 .79-.18 0-.45-.15-.67-.39-.32-.32-.45-.63-.82-2.08l-.9-3.39-.45-1.67h.76c.4 0 .75.02.75.05 0 .06 1.16 4.54 1.26 4.83.04.15.32-.7.73-2.3l.66-2.52.74-.04c.4-.02.73 0 .73.04 0 .14-1.67 6.38-1.8 6.68z"/></svg>
          Tech <span class="hidden sm:inline">({devtoPosts.length})</span>
        </button>
        <button data-filter="local" class="log-filter">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          Field <span class="hidden sm:inline">({localPosts.length})</span>
        </button>
      </div>

      <!-- Dev.to stats dashboard -->
      {devtoPosts.length > 0 && (
        <div id="devto-stats" class="card card-coord p-5 mb-8">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="text-[9px] font-mono faint tracking-wider">SIGNAL.DASHBOARD</span>
            <span class="w-3 border-t border-dashed border-[var(--color-faint)]/30"></span>
            <svg class="w-3.5 h-3.5 faint" viewBox="0 0 24 24" fill="currentColor"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-.72.04-.75.03v1.77l1.22.03 1.2.04v1.28h-1.6c-1.53 0-1.6-.01-1.87-.3l-.3-.28v-3.16c0-3.02.01-3.18.25-3.48.23-.31.25-.31 1.88-.31h1.64v1.3zm4.68 5.45c-.17.43-.64.79-1 .79-.18 0-.45-.15-.67-.39-.32-.32-.45-.63-.82-2.08l-.9-3.39-.45-1.67h.76c.4 0 .75.02.75.05 0 .06 1.16 4.54 1.26 4.83.04.15.32-.7.73-2.3l.66-2.52.74-.04c.4-.02.73 0 .73.04 0 .14-1.67 6.38-1.8 6.68z"/></svg>
            <a href={siteConfig.social.devto.url} target="_blank" rel="noopener noreferrer" class="text-[9px] font-mono faint hover:text-[var(--color-accent)] transition-colors tracking-wider ml-auto">@{siteConfig.social.devto.username} ↗</a>
          </div>
          <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-3">
            <div class="text-center">
              <div class="font-[family-name:var(--font-display)] text-2xl font-bold text-[var(--color-text)]">{devtoPosts.length}</div>
              <div class="text-[8px] font-mono faint tracking-[0.15em] uppercase mt-0.5">Transmissions</div>
            </div>
            <div class="text-center">
              <div class="font-[family-name:var(--font-display)] text-2xl font-bold text-[var(--color-accent)]">{totalViews.toLocaleString()}</div>
              <div class="text-[8px] font-mono faint tracking-[0.15em] uppercase mt-0.5">Scans</div>
            </div>
            <div class="text-center">
              <div class="font-[family-name:var(--font-display)] text-2xl font-bold accent-warm">{totalReactions}</div>
              <div class="text-[8px] font-mono faint tracking-[0.15em] uppercase mt-0.5">Reactions</div>
            </div>
            <div class="text-center">
              <div class="font-[family-name:var(--font-display)] text-2xl font-bold text-[var(--color-tertiary)]">{totalComments}</div>
              <div class="text-[8px] font-mono faint tracking-[0.15em] uppercase mt-0.5">Responses</div>
            </div>
          </div>
        </div>
      )}

      <!-- Entries container -->
      <div id="log-entries">
        <!-- Empty state -->
        <div id="log-empty" class="text-center py-16" style="display:none">
          <div class="flex items-center justify-center gap-2 mb-4">
            <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-warm)]"></div>
            <span class="text-[9px] font-mono faint tracking-[0.15em] uppercase">No Entries</span>
          </div>
          <p class="dim text-sm">No transmissions found on this frequency.</p>
        </div>

        <!-- Dev.to posts (pre-rendered at build time, shown by default) -->
        {devtoPosts.map((post) => (
          <a
            href={post.href}
            data-source="devto"
            class="log-entry group block py-7 pl-0 md:hover:pl-4 border-b border-[var(--color-edge)] hover:border-[var(--color-accent)]/40 transition-all duration-300"
          >
            <div class="flex items-center flex-wrap gap-x-3 gap-y-1 mb-2">
              <span class="log-entry-num font-mono text-[9px] text-[var(--color-accent)]/50 tracking-wider"></span>
              <span class="w-3 border-t border-dashed border-[var(--color-faint)]/30"></span>
              <span class="font-mono text-[11px] faint tracking-wider">
                {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <span class="faint">&middot;</span>
              <span class="font-mono text-[11px] faint">{post.readTime} min</span>
              <span class="faint">&middot;</span>
              <span class="font-mono text-[9px] text-[var(--color-tertiary)] tracking-wider">EXT</span>
            </div>
            <div class="flex items-center justify-between gap-4">
              <h2 class="font-[family-name:var(--font-display)] text-lg font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1.5">
                {post.title}
              </h2>
              <svg class="w-4 h-4 faint opacity-0 group-hover:opacity-100 group-hover:translate-x-0 -translate-x-2 transition-all duration-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <p class="dim text-sm leading-relaxed">{post.description}</p>
            {post.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {post.tags.map((tag: string, j: number) => <span class={j === 0 ? "tag-warm" : "tag"}>{tag}</span>)}
              </div>
            )}
            <div class="flex items-center gap-3 mt-2.5">
              {post.views > 0 && (
                <span class="flex items-center gap-1 text-[10px] font-mono faint">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  {post.views.toLocaleString()}
                </span>
              )}
              <span class="flex items-center gap-1 text-[10px] font-mono faint">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                {post.reactions}
              </span>
              <span class="flex items-center gap-1 text-[10px] font-mono faint">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                {post.comments}
              </span>
            </div>
          </a>
        ))}

        <!-- Local posts (pre-rendered, hidden by default) -->
        {localPosts.map((post) => (
          <a
            href={post.href}
            data-source="local"
            class="log-entry group block py-7 pl-0 md:hover:pl-4 border-b border-[var(--color-edge)] hover:border-[var(--color-accent)]/40 transition-all duration-300"
            style="display:none"
          >
            <div class="flex items-center flex-wrap gap-x-3 gap-y-1 mb-2">
              <span class="log-entry-num font-mono text-[9px] text-[var(--color-accent)]/50 tracking-wider"></span>
              <span class="w-3 border-t border-dashed border-[var(--color-faint)]/30"></span>
              <span class="font-mono text-[11px] faint tracking-wider">
                {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              {post.location && (
                <>
                  <span class="faint">&middot;</span>
                  <span class="font-mono text-[11px] faint">{post.location}</span>
                </>
              )}
              <span class="faint">&middot;</span>
              <span class="font-mono text-[11px] faint">{post.readTime} min</span>
            </div>
            <div class="flex items-center justify-between gap-4">
              <h2 class="font-[family-name:var(--font-display)] text-lg font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1.5">
                {post.title}
              </h2>
              <svg class="w-4 h-4 faint opacity-0 group-hover:opacity-100 group-hover:translate-x-0 -translate-x-2 transition-all duration-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <p class="dim text-sm leading-relaxed">{post.description}</p>
            {post.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {post.tags.map((tag: string, j: number) => <span class={j === 0 ? "tag-warm" : "tag"}>{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>

      <!-- Pagination -->
      <div class="flex items-center justify-between mt-10 pt-6 border-t border-dashed border-[var(--color-edge)]" id="log-pagination" style="display:none">
        <button id="page-prev" class="btn-ghost magnetic text-sm" disabled>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          <span>Prev</span>
        </button>
        <span class="text-[10px] font-mono faint tracking-wider" id="page-info"></span>
        <button id="page-next" class="btn-ghost magnetic text-sm">
          <span>Next</span>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <script>
    const PER_PAGE = 6;
    const container = document.getElementById('log-entries')!;
    const buttons = document.querySelectorAll<HTMLButtonElement>('#log-filters .log-filter');
    const prevBtn = document.getElementById('page-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('page-next') as HTMLButtonElement;
    const pageInfo = document.getElementById('page-info')!;
    const pagination = document.getElementById('log-pagination')!;
    const statsCard = document.getElementById('devto-stats');

    let currentFilter = 'devto';
    let currentPage = 1;

    const techEntries = Array.from(container.querySelectorAll<HTMLElement>('.log-entry[data-source="devto"]'));
    const localEntries = Array.from(container.querySelectorAll<HTMLElement>('.log-entry[data-source="local"]'));

    function getFiltered(): HTMLElement[] {
      return currentFilter === 'devto' ? techEntries : localEntries;
    }

    function render() {
      const filtered = getFiltered();
      const totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      currentPage = Math.min(currentPage, totalPages);
      const start = (currentPage - 1) * PER_PAGE;
      const end = start + PER_PAGE;

      // Hide everything
      techEntries.forEach(e => e.style.display = 'none');
      localEntries.forEach(e => e.style.display = 'none');

      // Stats dashboard — only visible on tech tab
      if (statsCard) statsCard.style.display = currentFilter === 'devto' ? '' : 'none';

      // Empty state
      const emptyState = document.getElementById('log-empty');
      if (emptyState) emptyState.style.display = filtered.length === 0 ? '' : 'none';

      // Show current page
      filtered.forEach((e, i) => {
        e.style.display = (i >= start && i < end) ? '' : 'none';
        const numEl = e.querySelector('.log-entry-num');
        if (numEl) numEl.textContent = `ENT.${String(filtered.length - i).padStart(3, '0')}`;
      });

      // Pagination
      pageInfo.textContent = `${String(currentPage).padStart(2, '0')} / ${String(totalPages).padStart(2, '0')}`;
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
      pagination.style.display = totalPages <= 1 ? 'none' : '';
    }

    // Filter buttons
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('log-filter-active'));
        btn.classList.add('log-filter-active');
        currentFilter = btn.dataset.filter!;
        currentPage = 1;
        render();
      });
    });

    // Pagination
    function scrollToEntries() {
      const el = document.getElementById('log-filters');
      if (el) {
        const y = el.getBoundingClientRect().top + window.scrollY - 100;
        window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
      }
    }
    prevBtn.addEventListener('click', () => { currentPage--; render(); scrollToEntries(); });
    nextBtn.addEventListener('click', () => { currentPage++; render(); scrollToEntries(); });

    // Init — render immediately, everything is already in the DOM
    render();
  </script>

</BaseLayout>
