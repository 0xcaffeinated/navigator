---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
---

<BaseLayout title={`Signal Lost — ${siteConfig.name.full}`} noindex={true}>

  <!-- Standard 404 (shown when URL doesn't match /blog/dev/) -->
  <section id="not-found" class="relative min-h-[70vh] flex items-center justify-center px-6 md:px-12">
    <div class="absolute inset-0 topo-grid"></div>
    <div class="text-center relative reveal">
      <div class="flex items-center justify-center gap-2 mb-6">
        <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-warm)]"></div>
        <span class="text-[9px] font-mono faint tracking-[0.15em] uppercase">Signal Lost</span>
      </div>
      <h1 class="font-[family-name:var(--font-display)] text-6xl md:text-8xl font-bold text-[var(--color-text)] mb-4">404</h1>
      <p class="dim text-lg mb-8 max-w-md mx-auto">This coordinate doesn't exist on the map. The route may have changed.</p>
      <a href="/" class="btn-primary magnetic">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4"/></svg>
        <span>Return to base</span>
      </a>
    </div>
  </section>

  <!-- Live article reader (shown when URL matches /blog/dev/) -->
  <article id="live-reader" class="relative pt-20 pb-16 md:pt-32 md:pb-24 px-6 md:px-12" style="display:none">
    <div class="absolute inset-0 topo-grid"></div>
    <div class="max-w-3xl mx-auto relative">
      <a href="/blog" class="inline-flex items-center gap-2 dim hover:text-[var(--color-accent)] hover:-translate-x-1 transition-all duration-200 mb-14 reveal text-sm group font-mono">
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Return to logbook
      </a>

      <!-- Loading -->
      <div id="live-loading" class="flex items-center justify-center py-32">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] animate-pulse"></span>
        <span class="text-[9px] font-mono faint tracking-wider ml-2">Receiving transmission...</span>
      </div>

      <!-- Error -->
      <div id="live-error" style="display:none" class="text-center py-32">
        <div class="flex items-center justify-center gap-2 mb-6">
          <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-warm)]"></div>
          <span class="text-[9px] font-mono faint tracking-[0.15em] uppercase">Transmission Failed</span>
        </div>
        <p class="dim text-lg mb-8">Could not receive this signal. The source may be unavailable.</p>
        <a href="/blog" class="btn-primary magnetic">
          <span>Return to logbook</span>
        </a>
      </div>

      <!-- Article content (filled by JS) -->
      <div id="live-content" style="display:none">
        <header class="mb-14">
          <div class="flex items-center gap-2 mb-5">
            <div class="w-1 h-1 rounded-full bg-[var(--color-tertiary)]"></div>
            <span class="text-[9px] font-mono faint tracking-[0.15em] uppercase">Log Entry</span>
            <span class="text-[9px] font-mono faint">&middot;</span>
            <span class="text-[9px] font-mono faint tracking-wider" id="live-readtime"></span>
            <span class="text-[9px] font-mono faint">&middot;</span>
            <span class="text-[9px] font-mono text-[var(--color-tertiary)] tracking-wider">EXT</span>
          </div>
          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="tag-warm" id="live-date"></span>
            <a id="live-devto-link" href="#" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-[9px] font-mono faint tracking-wider hover:text-[var(--color-accent)] transition-colors no-underline">
              <span class="w-1 h-1 rounded-full bg-[var(--color-tertiary)]"></span>
              dev.to
              <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
          </div>
          <h1 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold text-[var(--color-text)] leading-[1.2] mb-4" id="live-title"></h1>
          <div class="flex flex-wrap gap-1.5 mt-5" id="live-tags"></div>
        </header>

        <div class="separator mb-12"></div>

        <div class="prose" id="live-body"></div>

        <!-- Engage on dev.to -->
        <div class="mt-16 mb-6 card p-6">
          <div class="flex items-center gap-2 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
            <span class="text-[9px] font-mono faint tracking-[0.15em] uppercase">Join the discussion</span>
          </div>
          <p class="dim text-sm leading-relaxed mb-5">Liked this entry? React, comment, or bookmark it on dev.to — that's where the conversation lives.</p>
          <div class="flex flex-wrap gap-2.5" id="live-engage">
            <a href="#" data-engage="comments" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 px-4 py-2.5 rounded-lg border border-[var(--color-edge)] hover:border-[var(--color-accent)]/40 transition-all duration-200">
              <svg class="w-3.5 h-3.5 faint group-hover:text-[var(--color-accent)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              <span class="text-[11px] font-mono faint group-hover:text-[var(--color-accent)] transition-colors tracking-wider">Comment</span>
            </a>
            <a href="#" data-engage="react" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 px-4 py-2.5 rounded-lg border border-[var(--color-edge)] hover:border-[var(--color-warm)]/40 transition-all duration-200">
              <svg class="w-3.5 h-3.5 faint group-hover:text-[var(--color-warm)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              <span class="text-[11px] font-mono faint group-hover:text-[var(--color-warm)] transition-colors tracking-wider">React</span>
            </a>
            <a href="#" data-engage="bookmark" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 px-4 py-2.5 rounded-lg border border-[var(--color-edge)] hover:border-[var(--color-tertiary)]/40 transition-all duration-200">
              <svg class="w-3.5 h-3.5 faint group-hover:text-[var(--color-tertiary)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
              <span class="text-[11px] font-mono faint group-hover:text-[var(--color-tertiary)] transition-colors tracking-wider">Bookmark</span>
            </a>
          </div>
        </div>

        <!-- Refuel -->
        <div class="mb-16 flex justify-center">
          <a href={siteConfig.social.buymeacoffee.url} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2.5 px-5 py-3 rounded-xl border border-dashed border-[var(--color-edge)] hover:border-[var(--color-warm)]/40 transition-all duration-300">
            <svg class="w-4 h-4 text-[var(--color-warm)] opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 8h1a4 4 0 110 8h-1M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8zM6 2v4M10 2v4M14 2v4"/></svg>
            <span class="text-[11px] font-mono faint group-hover:text-[var(--color-warm)] transition-colors tracking-wider">Refuel the navigator</span>
          </a>
        </div>

        <div class="pt-8 border-t border-dashed border-[var(--color-edge)] flex flex-wrap items-center justify-between gap-3">
          <a href="/blog" class="btn-ghost magnetic">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            <span>All entries</span>
          </a>
          <a id="live-devto-link-bottom" href="#" target="_blank" rel="noopener noreferrer" class="btn-ghost magnetic text-sm">
            <span>View on dev.to</span>
            <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>
    </div>
  </article>

  <script is:inline define:vars={{ devtoUsername: siteConfig.social.devto.username, siteName: siteConfig.name.full }}>
    window.__siteConfig = { devtoUsername, siteName };
  </script>
  <script>
    const path = window.location.pathname;
    const match = path.match(/^\/blog\/dev\/(.+?)\/?$/);

    if (match) {
      document.getElementById('not-found')!.style.display = 'none';
      document.getElementById('live-reader')!.style.display = '';

      const slug = match[1];
      const cfg = (window as any).__siteConfig;

      function cleanTitle(title: string) {
        return title.replace(/^[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}\u{FE00}-\u{FE0F}\u{200D}\u{20E3}\u{E0020}-\u{E007F}]+\s*/u, '');
      }

      (async () => {
        try {
          // Paginate to find the article by slug
          let found: any = null;
          for (let page = 1; page <= 10; page++) {
            const res = await fetch(`https://dev.to/api/articles?username=${cfg.devtoUsername}&per_page=100&page=${page}`);
            if (!res.ok) break;
            const articles = await res.json();
            if (articles.length === 0) break;
            found = articles.find((a: any) => a.slug === slug);
            if (found || articles.length < 100) break;
          }

          if (!found) throw new Error('Article not found');

          // Fetch full article content
          const fullRes = await fetch(`https://dev.to/api/articles/${found.id}`);
          if (!fullRes.ok) throw new Error('Fetch failed');
          const article = await fullRes.json();

          // Populate the page
          document.title = `${cleanTitle(article.title)} — ${cfg.siteName}`;

          document.getElementById('live-title')!.textContent = cleanTitle(article.title);
          document.getElementById('live-readtime')!.textContent = `${article.reading_time_minutes} min transmission`;
          document.getElementById('live-date')!.textContent = new Date(article.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
          document.getElementById('live-body')!.innerHTML = article.body_html;

          // Links
          const articleUrl = article.url;
          (document.getElementById('live-devto-link') as HTMLAnchorElement).href = articleUrl;
          (document.getElementById('live-devto-link-bottom') as HTMLAnchorElement).href = articleUrl;

          // Engagement links
          const engageLinks = document.querySelectorAll<HTMLAnchorElement>('#live-engage a');
          engageLinks.forEach(link => {
            const type = link.dataset.engage;
            link.href = type === 'comments' ? `${articleUrl}#comments` : articleUrl;
          });

          // Tags
          const tagsEl = document.getElementById('live-tags')!;
          (article.tags as string[]).forEach(t => {
            const span = document.createElement('span');
            span.className = 'tag';
            span.textContent = t;
            tagsEl.appendChild(span);
          });

          // Hide broken images
          document.querySelectorAll('#live-body img').forEach(img => {
            (img as HTMLImageElement).addEventListener('error', () => {
              img.setAttribute('data-broken', '');
            });
          });

          // Show content, hide loading
          document.getElementById('live-loading')!.style.display = 'none';
          document.getElementById('live-content')!.style.display = '';

        } catch {
          document.getElementById('live-loading')!.style.display = 'none';
          document.getElementById('live-error')!.style.display = '';
        }
      })();
    }
  </script>

</BaseLayout>
